# ─────────────────────────────────────────────────────────────────────────────
# Environment variables for the User Management API
# Copy this file to .env and fill in your values before starting the app.
# Never commit the real .env file to version control.
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL connection
DB_HOST=localhost
DB_PORT=5432
DB_NAME=usermanagement
DB_USERNAME=postgres
DB_PASSWORD=postgres
